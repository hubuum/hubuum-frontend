# Required base URL for the Hubuum backend API.
# During `npm run dev`, Next.js runs on the host, so this URL must be reachable
# from the host. If the backend publishes port 8080 locally, use:
BACKEND_BASE_URL=http://127.0.0.1:8080

# Required Valkey/Redis URL for server-side sessions.
# `npm run dev:deps` exposes the development instance on this address.
VALKEY_URL=redis://127.0.0.1:6379/0

# Session lifetime for opaque backend tokens (in seconds).
SESSION_TTL_SECONDS=28800

# Optional namespace prefix for session keys in Valkey.
SESSION_PREFIX=hubuum:sess:

# Optional namespace prefix for the temporary user-settings fallback in Valkey.
SETTINGS_PREFIX=hubuum:settings:

# Public app title
NEXT_PUBLIC_APP_NAME=Hubuum Console

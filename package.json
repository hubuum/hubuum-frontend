{
	"name": "hubuum-frontend",
	"version": "0.0.1",
	"private": true,
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "next dev",
		"dev:deps": "docker compose -f compose.dev.yml up -d --wait",
		"dev:deps:down": "docker compose -f compose.dev.yml down",
		"build": "next build",
		"start": "node scripts/start-standalone.mjs",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:public": "playwright test tests/e2e/public-ui.spec.ts",
		"test:e2e:update": "playwright test tests/e2e/public-ui.spec.ts --update-snapshots",
		"test:live-backend": "scripts/live-backend-test.sh",
		"lint": "biome lint .",
		"typecheck": "next typegen && tsc --noEmit",
		"gen:api": "npx --yes orval@8.4.1 --config orval.config.mjs && node scripts/patch-generated-client-prefix.mjs",
		"audit:prod": "npm audit --omit=dev"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.2",
		"@codemirror/lang-jinja": "^6.0.1",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/language": "^6.12.4",
		"@codemirror/lint": "^6.9.7",
		"@codemirror/state": "^6.7.1",
		"@codemirror/view": "^6.43.6",
		"@lezer/highlight": "^1.2.3",
		"@tanstack/react-query": "^5.101.2",
		"@types/prismjs": "^1.26.6",
		"codemirror": "^6.0.2",
		"fflate": "0.8.3",
		"ioredis": "^5.10.1",
		"next": "^16.2.10",
		"prismjs": "^1.30.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-simple-code-editor": "^0.14.1",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"zod": "^4.4.3"
	},
	"overrides": {
		"postcss": "8.5.10"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@biomejs/biome": "^2.4.15",
		"@playwright/test": "^1.61.1",
		"@types/node": "^25.9.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "^6.0.3",
		"vitest": "^3.2.6"
	}
}

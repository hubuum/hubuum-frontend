		"@lezer/highlight": "^1.2.3",
		"@tanstack/react-query": "^5.100.10",
		"@types/prismjs": "^1.26.6",
		"codemirror": "^6.0.2",
		"ioredis": "^5.10.1",
		"next": "^16.2.6",
		"prismjs": "^1.30.0",
		"react": "^19.2.6",

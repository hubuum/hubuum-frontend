# Required: URL the frontend container can use to reach Hubuum Server.
# For a remote server, use its normal HTTPS URL.
# For Docker Engine on Linux, host.docker.internal may require an explicit
# host-gateway mapping; see docs/quickstart-compose.md.
BACKEND_BASE_URL=https://hubuum-api.example.com

# Optional local overrides.
HUBUUM_FRONTEND_PORT=3000
HUBUUM_FRONTEND_IMAGE=ghcr.io/hubuum/hubuum-frontend:v0.0.2
NEXT_PUBLIC_APP_NAME=Hubuum Console
SESSION_TTL_SECONDS=28800
SESSION_PREFIX=hubuum:sess:
SETTINGS_PREFIX=hubuum:settings:

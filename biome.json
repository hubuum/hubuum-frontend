{
	"$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/.next",
			"!playwright-report",
			"!test-results",
			"!src/lib/api/generated"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"style": {
				"useImportType": "off"
			}
		}
	}
}
